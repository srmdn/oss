---
import Layout from "../components/Layout.astro";
---

<Layout
  title="About — srmdn/oss"
  description="About srmdn and open source contributions"
  currentPage="about"
>
  <section class="section">
    <h2 class="section-title">About</h2>
    <p style="max-width:560px;color:var(--text-muted);line-height:1.7">
      Open source developer contributing bugfixes and features across the Go and TypeScript ecosystems.
      Focused on real-world problems — fixing race conditions, adding missing CLI symmetry, patching middleware gaps.
    </p>
  </section>

  <section class="section">
    <h2 class="section-title">Projects</h2>
    <div class="about-grid">
      <div class="about-card">
        <h3>Paseo</h3>
        <p>CLI agent manager. Added <code>agent unarchive</code> command — inverse of existing archive operation.</p>
      </div>
      <div class="about-card">
        <h3>BillionMail</h3>
        <p>Email marketing platform. Fixed safepath middleware blocking tracking links in incognito/forwarded scenarios.</p>
      </div>
      <div class="about-card">
        <h3>Syncthing</h3>
        <p>Continuous file sync. Fixed PATCH endpoint resetting unspecified config fields to defaults.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Languages</h2>
    <div class="about-grid">
      <div class="about-card">
        <h3>Go</h3>
        <p>Primary language for backend contributions. Systems-level fixes, API patches, middleware.</p>
      </div>
      <div class="about-card">
        <h3>TypeScript</h3>
        <p>CLI tools, type-safe implementations. Astro for static sites.</p>
      </div>
    </div>
  </section>
</Layout>
