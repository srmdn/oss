---
import Layout from "../components/Layout.astro";
import Card from "../components/Card.astro";
import FilterBar from "../components/FilterBar.astro";
import { contributions, getStats, type Contribution } from "../data/contributions";

const stats = getStats();
const languages = [...new Set(contributions.map((c) => c.language))];
const types = [...new Set(contributions.map((c) => c.type))];
const statuses = [...new Set(contributions.map((c) => c.status))];
---

<Layout
  title="srmdn — OSS Contributions"
  description="Open source contributions by srmdn"
  currentPage="home"
>
  <section class="section">
    <div class="stats">
      <div class="stat">
        <span class="stat-number">{stats.total}</span>
        <span class="stat-label">Contributions</span>
      </div>
      <div class="stat">
        <span class="stat-number">{stats.open}</span>
        <span class="stat-label">Open PRs</span>
      </div>
      <div class="stat">
        <span class="stat-number">{stats.merged}</span>
        <span class="stat-label">Merged</span>
      </div>
      <div class="stat">
        <span class="stat-number">{stats.projects}</span>
        <span class="stat-label">Projects</span>
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">Pull Requests</h2>
    <FilterBar languages={languages} types={types} statuses={statuses} />

    <div class="contributions">
      {contributions.map((c) => (
        <Card contribution={c} />
      ))}
    </div>
  </section>
</Layout>

<style>
  .contributions {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
</style>
