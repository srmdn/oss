---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  currentPage?: "home" | "about";
}
const { title, description, currentPage } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL.slice(0, -1)
  : import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="container">
      <nav class="nav">
        <a href={`${base}/`} class="nav-brand"><span>srmdn</span>/oss</a>
        <div class="nav-links">
          <a href={`${base}/`} class={currentPage === "home" ? "active" : ""}>Contributions</a>
          <a href={`${base}/about/`} class={currentPage === "about" ? "active" : ""}>About</a>
          <a href="https://github.com/srmdn" target="_blank" rel="noopener">GitHub</a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
            🌙
          </button>
        </div>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="footer container">
      <a href="https://github.com/srmdn">@srmdn</a> on GitHub &mdash; built with Astro
    </footer>
  </body>
</html>

<script>
  const toggle = document.getElementById("theme-toggle")!;
  const html = document.documentElement;

  const stored = localStorage.getItem("theme");
  if (stored) {
    html.setAttribute("data-theme", stored);
    toggle.textContent = stored === "light" ? "☀️" : "🌙";
  } else {
    const prefers = window.matchMedia("(prefers-color-scheme: light)").matches;
    html.setAttribute("data-theme", prefers ? "light" : "dark");
    toggle.textContent = prefers ? "☀️" : "🌙";
  }

  toggle.addEventListener("click", () => {
    const current = html.getAttribute("data-theme");
    const next = current === "dark" ? "light" : "dark";
    html.setAttribute("data-theme", next);
    toggle.textContent = next === "light" ? "☀️" : "🌙";
    localStorage.setItem("theme", next);
  });
</script>
